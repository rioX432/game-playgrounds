{
  "name": "game-playgrounds-electron-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell that wraps a built web playground (three/ or babylon/ dist) for Steam packaging. Standalone — not part of the engine projects' builds.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.example.gameplaygrounds",
    "productName": "Game Playgrounds",
    "files": [
      "main.cjs"
    ],
    "extraResources": [
      {
        "from": "../../three/dist",
        "to": "web"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
